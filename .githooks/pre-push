#!/bin/sh

allow_dev="${SAFE_PUSH_ALLOW_DEV:-0}"

while read local_ref local_sha remote_ref remote_sha
do
  case "$remote_ref" in
    refs/heads/main|refs/heads/pre-prod)
      echo "Push blocked: direct push to '${remote_ref#refs/heads/}' is forbidden." >&2
      exit 1
      ;;
    refs/heads/feature/*)
      continue
      ;;
    refs/heads/dev)
      if [ "$allow_dev" = "1" ]; then
        continue
      fi
      echo "Push blocked: 'dev' requires SAFE_PUSH_ALLOW_DEV=1." >&2
      exit 1
      ;;
    refs/heads/*)
      echo "Push blocked: only 'feature/*' branches are allowed directly (and optional 'dev')." >&2
      echo "Attempted target: '${remote_ref#refs/heads/}'." >&2
      exit 1
      ;;
  esac
done

exit 0
